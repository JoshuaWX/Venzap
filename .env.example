# Database
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/venzap

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-super-secret-jwt-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Payaza
PAYAZA_SECRET_KEY=your-payaza-secret-key
PAYAZA_BASE_URL=https://api.payaza.africa
PAYAZA_DVA_ENDPOINT=/live/payaza-account/api/v1/dva

# Telegram
TELEGRAM_BOT_TOKEN=

# Bot -> API
BACKEND_API_BASE_URL=http://localhost:8000

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# AI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
AI_MAX_RESPONSE_TOKENS=300
AI_MAX_CONTEXT_TOKENS=2000
AI_CONFIDENCE_THRESHOLD=0.6
AI_REQUEST_TIMEOUT_SECONDS=5
AI_CACHE_TTL_SECONDS=60
AI_DAILY_TOKEN_BUDGET=33333
INTERNAL_AI_SECRET=your-long-random-internal-secret

# Support
SUPPORT_EMAIL=support@venzap.ng